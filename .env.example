# AI Threat Detection System - Environment Variables
# Copy this file to .env and customize

# Application
DEBUG=True

# API
API_HOST=0.0.0.0
API_PORT=8001

# Database (SQLite for development)
DATABASE_URL=sqlite:///./threat_detection.db

# Kafka (set KAFKA_ENABLED=True when ready)
KAFKA_ENABLED=False
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_LOGS=security-logs
